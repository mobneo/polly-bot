# Your private key (starts with 0x)
POLYMARKET_PRIVATE_KEY=your_private_key_here

# Signature type: proxy (default), eoa, or gnosis-safe
POLYMARKET_SIGNATURE_TYPE=your_polymarket_signature_type-here

# Log level: info, debug, trace, warn, error
RUST_LOG=your_rust_log_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# User IDs that can use the bot (comma-separated)
AUTHORIZED_USER_IDS=your_telegram_user_id_here

# Set to true to allow all users (for testing only)
ALLOW_ALL_USERS=false
